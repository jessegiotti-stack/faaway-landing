# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Bibliotecas de trabalho não versionadas (brutos HighFlux / dumps soltos).
# Apenas os ativos curados em assets/photos, assets/videos, assets/brand entram no repo.
/assets/lp_novas/
/assets/*.jpeg
/assets/*.jpg
/assets/*.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# netlify
.netlify


# typescript
*.tsbuildinfo
next-env.d.ts
